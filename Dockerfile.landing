FROM node:20-alpine
WORKDIR /app

ARG LANDING_BASE_URL=https://snt-portal.ru
ARG APP_LOGIN_URL=https://app.snt-portal.ru/login
ARG DEMO_EMAIL=hello@snt-portal.ru
ARG LANDING_GOOGLE_SITE_VERIFICATION=
ARG LANDING_YANDEX_SITE_VERIFICATION=

ENV LANDING_BASE_URL=$LANDING_BASE_URL
ENV APP_LOGIN_URL=$APP_LOGIN_URL
ENV DEMO_EMAIL=$DEMO_EMAIL
ENV LANDING_GOOGLE_SITE_VERIFICATION=$LANDING_GOOGLE_SITE_VERIFICATION
ENV LANDING_YANDEX_SITE_VERIFICATION=$LANDING_YANDEX_SITE_VERIFICATION

COPY landing/package*.json ./
RUN npm install
COPY landing ./

RUN npm run build

EXPOSE 3002
CMD ["npm","run","start","--","-p","3002"]
